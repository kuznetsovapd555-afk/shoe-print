      "source": [
        "from torch.utils.data import random_split\n",
        "\n",
        "# Определим размеры выборок\n",
        "total_size = len(segmentation_dataset)\n",
        "unseen_size = 5 # Количество изображений для финальной проверки\n",
        "\n",
        "# Если общее количество изображений меньше, чем нужно для \"невидимой\" выборки\n",
        "if total_size < unseen_size:\n",
        "    print(f\"Предупреждение: Недостаточно изображений ({total_size}) для резервирования {unseen_size} для финальной проверки. Все доступные изображения будут использованы как 'невидимая' выборка.\")\n",
        "    unseen_dataset = segmentation_dataset\n",
        "    train_dataset = [] # Оставляем остальные выборки пустыми\n",
        "    val_dataset = []\n",
        "    test_dataset = []\n",
        "else:\n",
        "    # 1. Сначала отделяем выборку для финальной проверки\n",
        "    unseen_dataset, remaining_dataset = random_split(segmentation_dataset, [unseen_size, total_size - unseen_size])\n",
        "\n",
        "    # 2. Затем делим оставшийся датасет на обучающую, валидационную и тестовую выборки\n",
        "    remaining_total_size = len(remaining_dataset)\n",
        "    train_size = int(0.7 * remaining_total_size)\n",
        "    val_size = int(0.15 * remaining_total_size)\n",
        "    test_size = remaining_total_size - train_size - val_size\n",
        "\n",
        "    # Корректируем размеры из-за округления, чтобы сумма соответствовала remaining_total_size\n",
        "    sizes = [train_size, val_size, test_size]\n",
        "    if sum(sizes) != remaining_total_size:\n",
        "        diff = remaining_total_size - sum(sizes)\n",
        "        train_size += diff # Добавляем/вычитаем разницу из самой большой выборки (обучающей)\n",
        "\n",
        "    train_dataset, val_dataset, test_dataset = random_split(remaining_dataset, [train_size, val_size, test_size])\n",
        "\n",
        "print(f\"Размер выборки для финальной проверки (невидимая для обучения): {len(unseen_dataset)}\")\n",
        "print(f\"Размер обучающей выборки: {len(train_dataset)}\")\n",
        "print(f\"Размер валидационной выборки: {len(val_dataset)}\")\n",
        "print(f\"Размер тестовой выборки: {len(test_dataset)}\")\n",
        "\n",
        "# Создаем DataLoader для каждой выборки\n",
        "unseen_dataloader = DataLoader(unseen_dataset, batch_size=batch_size, shuffle=False, num_workers=2) # Для финальной проверки без перемешивания\n",
        "train_dataloader = DataLoader(train_dataset, batch_size=batch_size, shuffle=True, num_workers=2)\n",
        "val_dataloader = DataLoader(val_dataset, batch_size=batch_size, shuffle=False, num_workers=2)\n",
        "test_dataloader = DataLoader(test_dataset, batch_size=batch_size, shuffle=False, num_workers=2)\n",
        "\n",
        "print(f\"\\nКоличество батчей в выборке для финальной проверки: {len(unseen_dataloader)}\")\n",
        "print(f\"Количество батчей в обучающей выборке: {len(train_dataloader)}\")\n",
        "print(f\"Количество батчей в валидационной выборке: {len(val_dataloader)}\")\n",
        "print(f\"Количество батчей в тестовой выборке: {len(test_dataloader)}\")"
      ]
