        "# criterion = nn.BCEWithLogitsLoss(pos_weight=torch.tensor([4]).to(device)) # Подходит для бинарной сегментации с одним каналом выхода\n",
        "# optimizer = optim.Adam(model.parameters(), lr=0.001)\n",
        "\n",
        "criterion = nn.BCEWithLogitsLoss() # Подходит для бинарной сегментации с одним каналом выхода\n",
        "optimizer = optim.Adam(model.parameters(), lr=0.001)\n",
        "\n",
        "num_epochs = 25 # Вы можете изменить количество эпох\n",
        "\n",
        "train_losses = []\n",
        "val_losses = []\n",
        "\n",
        "print(\"Начало обучения...\")\n",
        "\n",
        "for epoch in range(num_epochs):\n",
        "    model.train() # Переводим модель в режим обучения\n",
        "    running_train_loss = 0.0\n",
        "    for images, masks in train_dataloader:\n",
        "        images = images.to(device)\n",
        "        masks = masks.to(device)\n",
        "\n",
        "        # Прямой проход\n",
        "        outputs = model(images)\n",
        "        loss = criterion(outputs, masks)\n",
        "\n",
        "        # Обратный проход и оптимизация\n",
        "        optimizer.zero_grad()\n",
        "        loss.backward()\n",
        "        optimizer.step()\n",
        "\n",
        "        running_train_loss += loss.item() * images.size(0)\n",
        "\n",
        "    epoch_train_loss = running_train_loss / len(train_dataset)\n",
        "    train_losses.append(epoch_train_loss)\n",
        "\n",
        "    # Валидация\n",
        "    model.eval() # Переводим модель в режим оценки\n",
        "    running_val_loss = 0.0\n",
        "    with torch.no_grad(): # Отключаем расчет градиентов для валидации\n",
        "        for images, masks in val_dataloader:\n",
        "            images = images.to(device)\n",
        "            masks = masks.to(device)\n",
        "\n",
        "            outputs = model(images)\n",
        "            loss = criterion(outputs, masks)\n",
        "\n",
        "            running_val_loss += loss.item() * images.size(0)\n",
        "\n",
        "    epoch_val_loss = running_val_loss / len(val_dataset)\n",
        "    val_losses.append(epoch_val_loss)\n",
        "\n",
        "    print(f\"Эпоха {epoch+1}/{num_epochs}, Обучающая потеря: {epoch_train_loss:.4f}, Валидационная потеря: {epoch_val_loss:.4f}\")\n",
        "\n",
        "print(\"Обучение завершено!\")"
      ]
