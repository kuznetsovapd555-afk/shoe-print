      "source": [
        "import segmentation_models_pytorch as smp\n",
        "import torch\n",
        "\n",
        "# Определяем используемое устройство\n",
        "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
        "print(f\"Используемое устройство: {device}\")\n",
        "\n",
        "# Количество входных каналов (3 для RGB изображений)\n",
        "ENCODER_WEIGHTS = 'imagenet'\n",
        "ACTIVATION = None\n",
        "N_CLASSES = 1\n",
        "\n",
        "# ==== Доступные модели из segmentation_models_pytorch ====\n",
        "# U-Net: smp.Unet\n",
        "# FPN: smp.FPN (используется ниже)\n",
        "# PSPNet: smp.PSPNet\n",
        "# DeepLabV3: smp.DeepLabV3\n",
        "# DeepLabV3+: smp.DeepLabV3Plus\n",
        "\n",
        "# ==== Популярные энкодеры ====\n",
        "# ResNet: 'resnet18', 'resnet34', 'resnet50', 'resnet101', 'resnet152'\n",
        "# EfficientNet: 'efficientnet-b0', 'efficientnet-b1', ..., 'efficientnet-b7'\n",
        "# MobileNet: 'mobilenet_v2'\n",
        "# VGG: 'vgg11', 'vgg13', 'vgg16', 'vgg19'\n",
        "# DenseNet: 'densenet121', 'densenet169', 'densenet201'\n",
        "\n",
        "pretrained_model_1 = smp.UnetPlusPlus(\n",
        "    encoder_name='vgg19',        # mobilenet_v2 - отличный резульат\n",
        "    encoder_weights=ENCODER_WEIGHTS, # Используем предобученные веса ImageNet\n",
        "    in_channels=3,                  # Количество входных каналов (RGB)\n",
        "    classes=N_CLASSES,              # Количество классов для сегментации (1 для бинарной)\n",
        "    activation=ACTIVATION,          # 'sigmoid' для бинарной сегментации, если не используем BCEWithLogitsLoss\n",
        "    encoder_depth=5\n",
        ")\n",
        "\n",
        "pretrained_model_1.to(device)\n",
        "\n",
        "print(\"Предобученная модель успешно инициализирована.\")"
      ]
