        "import segmentation_models_pytorch as smp\n",
        "import torch\n",
        "\n",
        "# Определяем используемое устройство\n",
        "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
        "print(f\"Используемое устройство: {device}\")\n",
        "\n",
        "# Количество входных каналов (3 для RGB изображений)\n",
        "ENCODER_WEIGHTS = 'imagenet' # Используем веса, предобученные на ImageNet\n",
        "ACTIVATION = None            # Без активации на выходе, так как используем BCEWithLogitsLoss\n",
        "N_CLASSES = 1                # Для бинарной сегментации (фон/объект)\n",
        "\n",
        "# Инициализация UNet модели с предобученным энкодером ResNet34\n",
        "# Вы можете попробовать и другие энкодеры, например 'resnet50', 'efficientnet-b0' и т.д.\n",
        "pretrained_model = smp.Unet(\n",
        "    encoder_name='resnet34',        # Выбираем энкодер (например, ResNet34)\n",
        "    encoder_weights=ENCODER_WEIGHTS, # Используем предобученные веса ImageNet\n",
        "    in_channels=3,                  # Количество входных каналов (RGB)\n",
        "    classes=N_CLASSES,              # Количество классов для сегментации (1 для бинарной)\n",
        "    activation=ACTIVATION           # 'sigmoid' для бинарной сегментации, если не используем BCEWithLogitsLoss\n",
        ")\n",
        "\n",
        "pretrained_model.to(device)\n",
        "\n",
        "print(\"Предобученная модель U-Net успешно инициализирована с энкодером ResNet34.\")"
      ]
