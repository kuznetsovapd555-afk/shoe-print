        "import os\n",
        "from PIL import Image\n",
        "import torch\n",
        "from torch.utils.data import Dataset, DataLoader\n",
        "from torchvision import transforms\n",
        "\n",
        "# 1. Монтируем Google Drive\n",
        "from google.colab import drive\n",
        "drive.mount('/content/drive')\n",
        "\n",
        "# 2. Определяем путь к вашей папке dataset на Google Drive\n",
        "# Убедитесь, что путь '/content/drive/MyDrive/dataset' соответствует расположению вашей папки.\n",
        "# Например, если папка dataset находится в корне My Drive, то путь правильный.\n",
        "# Если она в другой папке, например, 'МоиПапки/dataset', то измените на '/content/drive/MyDrive/МоиПапки/dataset'\n",
        "dataset_root_dir = '/content/drive/MyDrive/annotated-merged'\n",
        "\n",
        "# Проверка существования папки\n",
        "if not os.path.exists(dataset_root_dir):\n",
        "    print(f\"Ошибка: Папка '{dataset_root_dir}' не найдена. Пожалуйста, проверьте путь к вашей папке 'dataset'.\")\n",
        "    print(\"Убедитесь, что внутри 'dataset' есть папки 'img' (для изображений) и 'mask' (для масок).\")\n",
        "else:\n",
        "    print(f\"Папка '{dataset_root_dir}' найдена. Продолжаем загрузку данных.\")\n",
        "\n",
        "# 3. Создаем пользовательский класс Dataset для семантической сегментации\n",
        "class SegmentationDataset(Dataset):\n",
        "    def __init__(self, root_dir, transform=None):\n",
        "        self.root_dir = root_dir\n",
        "        self.transform = transform\n",
        "        self.image_dir = os.path.join(root_dir, 'img')\n",
        "        self.mask_dir = os.path.join(root_dir, 'mask')\n",
        "\n",
        "        if not os.path.exists(self.image_dir):\n",
        "            raise FileNotFoundError(f\"Папка с изображениями '{self.image_dir}' не найдена.\")\n",
        "        if not os.path.exists(self.mask_dir):\n",
        "            raise FileNotFoundError(f\"Папка с масками '{self.mask_dir}' не найдена.\")\n",
        "\n",
        "        self.images = sorted(os.listdir(self.image_dir))\n",
        "        self.masks = sorted(os.listdir(self.mask_dir))\n",
        "\n",
        "        # Убедимся, что количество изображений и масок совпадает\n",
        "        if len(self.images) != len(self.masks):\n",
        "            print(f\"Предупреждение: Количество изображений ({len(self.images)}) и масок ({len(self.masks)}) не совпадает.\")\n",
        "\n",
        "        # Можно добавить проверку на соответствие имен файлов, если они должны быть одинаковыми.\n",
        "        # Например: assert [f.split('.')[0] for f in self.images] == [f.split('.')[0] for f in self.masks]\n",
        "\n",
        "    def __len__(self):\n",
        "        return len(self.images)\n",
        "\n",
        "    def __getitem__(self, idx):\n",
        "        if torch.is_tensor(idx):\n",
        "            idx = idx.tolist()\n",
        "\n",
        "        img_name = os.path.join(self.image_dir, self.images[idx])\n",
        "        mask_name = os.path.join(self.mask_dir, self.masks[idx]) # Предполагаем, что порядок файлов совпадает\n",
        "\n",
        "        image = Image.open(img_name).convert(\"RGB\") # Для изображений\n",
        "        mask = Image.open(mask_name).convert(\"L\")  # Для масок (одноканальное изображение)\n",
        "\n",
        "        if self.transform:\n",
        "            image, mask = self.transform(image, mask) # Передаем оба аргумента и распаковываем результат\n",
        "\n",
        "        return image, mask\n",
        "\n",
        "# 4. Определяем трансформации для изображений и масок\n",
        "# Для сегментации часто нужно изменять размер и конвертировать в тензор.\n",
        "# Маски обычно не нормализуют в том же диапазоне, что и изображения.\n",
        "image_transform = transforms.Compose([\n",
        "    transforms.Resize((256, 256)), # Измените размер по необходимости\n",
        "    transforms.ToTensor(),         # Конвертирует изображение в тензор (0-1 диапазон)\n",
        "    #transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225]) # Нормализация для предобученных моделей ImageNet\n",
        "])\n",
        "\n",
        "mask_transform = transforms.Compose([\n",
        "    transforms.Resize((256, 256), interpolation=Image.NEAREST), # Для масок используем NEAREST для сохранения целостности пикселей\n",
        "    transforms.ToTensor(),                                     # Конвертирует маску в тензор (0-1 диапазон)\n",
        "    # Без нормализации для масок, так как они представляют классы\n",
        "])\n",
        "\n",
        "# 5. Создаем экземпляр Dataset\n",
        "try:\n",
        "    # Передаем обе трансформации. В __getitem__ можно применить их по отдельности\n",
        "    # или создать отдельную функцию для трансформаций в классе Dataset.\n",
        "    # Для простоты, здесь я применяю одну трансформацию к обоим.\n",
        "    # Более продвинутый подход: создать класс трансформации, который применяет разные ops для img/mask.\n",
        "    # Для начала, можно сделать так:\n",
        "\n",
        "    class CombinedTransforms:\n",
        "        def __init__(self, image_transform, mask_transform):\n",
        "            self.image_transform = image_transform\n",
        "            self.mask_transform = mask_transform\n",
        "\n",
        "        def __call__(self, image, mask):\n",
        "            return self.image_transform(image), self.mask_transform(mask)\n",
        "\n",
        "    # Инициализируем датасет с комбинированными трансформациями\n",
        "    full_transform = CombinedTransforms(image_transform, mask_transform)\n",
        "\n",
        "    segmentation_dataset = SegmentationDataset(root_dir=dataset_root_dir, transform=full_transform)\n",
        "\n",
        "    print(f\"Найдено {len(segmentation_dataset)} пар изображений/масок в датасете.\")\n",
        "\n",
        "    # 6. Создаем DataLoader для батчевой загрузки данных\n",
        "    batch_size = 4\n",
        "    dataloader = DataLoader(segmentation_dataset, batch_size=batch_size, shuffle=True, num_workers=2)\n",
        "\n",
        "    # Пример использования DataLoader\n",
        "    print(\"\\nПример загрузки одного батча:\")\n",
        "    for i, (images, masks) in enumerate(dataloader):\n",
        "        print(f\"Батч {i+1}:\")\n",
        "        print(f\"  Размер тензора изображений: {images.shape} (Batch_size, Channels, Height, Width)\")\n",
        "        print(f\"  Размер тензора масок: {masks.shape} (Batch_size, Channels, Height, Width)\")\n",
        "\n",
        "        # Визуализация первой пары из батча (опционально, требует matplotlib)\n",
        "        import matplotlib.pyplot as plt\n",
        "        import numpy as np\n",
        "\n",
        "        fig, ax = plt.subplots(1, 2, figsize=(10, 5))\n",
        "        ax[0].imshow(images[0].permute(1, 2, 0).cpu().numpy()) # Переставляем оси для отображения\n",
        "        ax[0].set_title('Изображение')\n",
        "        ax[0].axis('off')\n",
        "\n",
        "        ax[1].imshow(masks[0].squeeze().cpu().numpy(), cmap='gray') # squeeze() удаляет лишние измерения\n",
        "        ax[1].set_title('Маска')\n",
        "        ax[1].axis('off')\n",
        "        plt.show()\n",
        "\n",
        "        break # Останавливаемся после первого батча\n",
        "\n",
        "except FileNotFoundError as e:\n",
        "    print(f\"Ошибка при инициализации датасета: {e}\")\n",
        "except Exception as e:\n",
        "    print(f\"Произошла непредвиденная ошибка: {e}\")"
      ]
